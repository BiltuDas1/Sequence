# This is an example of what your keystore.properties file should look like.
# Copy this file to the root directory and name it 'keystore.properties'.
# Then fill in your own signing credentials.

# The path to your keystore (.jks) file.
# It can be an absolute path or relative to the 'app' directory.
# Example: C:/Users/billi/OneDrive/Documents/KeyFile
storeFile=path/to/your/keystore.jks

# The password for the keystore.
storePassword=your_store_password

# The alias assigned to your key.
keyAlias=your_key_alias

# The password for the key.
keyPassword=your_key_password
